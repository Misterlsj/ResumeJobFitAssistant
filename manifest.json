{
  "manifest_version": 3,
  "name": "Resume Job-Fit Assistant",
  "version": "1.0.0",
  "description": "Auto-detect job postings on LinkedIn, Indeed, Glassdoor, Lever & Greenhouse. One click to analyze with ResumeScorer. No AI needed.",
  "homepage_url": "https://resumescorer.com",
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.indeed.com/*",
    "https://www.glassdoor.com/*",
    "https://jobs.lever.co/*",
    "https://boards.greenhouse.io/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/view/*"],
      "js": ["content-scripts/detector.js", "content-scripts/linkedin.js", "sidebar/sidebar.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.indeed.com/viewjob*", "https://www.indeed.com/jobs*"],
      "js": ["content-scripts/detector.js", "content-scripts/indeed.js", "sidebar/sidebar.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.glassdoor.com/job-listing/*"],
      "js": ["content-scripts/detector.js", "content-scripts/glassdoor.js", "sidebar/sidebar.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://jobs.lever.co/*"],
      "js": ["content-scripts/detector.js", "content-scripts/lever.js", "sidebar/sidebar.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://boards.greenhouse.io/*/jobs/*"],
      "js": ["content-scripts/detector.js", "content-scripts/greenhouse.js", "sidebar/sidebar.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
